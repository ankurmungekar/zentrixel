# Copy this file to .env and fill in your values
# Generate a Gmail App Password at:
# Google Account → Security → 2-Step Verification → App Passwords

PORT=3001
GMAIL_USER=ankurmungekarstorage@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Origin allowed for CORS (your production domain, e.g. https://zentrixel.com)
# In development this defaults to localhost:5173
ALLOWED_ORIGIN=https://zentrixel.com
